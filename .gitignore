# =============================================================================
# BougeaParis.fr - .gitignore
# =============================================================================

# SECRETS - Ne JAMAIS commiter ces fichiers
# (le pattern secrets.* couvre aussi secrets.php.rtf, secrets.bak,
# secrets.local.php, etc. — gitignore ne supporte pas les commentaires inline)
public_html/config/secrets.php
public_html/config/secrets.*
.env
.env.local
*.secret

# Cache applicatif (genere sur le serveur)
public_html/api/cache/*
!public_html/api/cache/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editeurs / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Dependances (si un jour on utilise Composer ou npm)
/vendor/
/node_modules/
composer.lock
package-lock.json

# Deploiement FTP (cache du workflow GitHub Actions)
.ftp-deploy-sync-state.json

# Fichiers temporaires PHP
*.tmp
*.bak

# Archives
*.zip
*.tar
*.tar.gz

# Cache GTFS (telecharge par scripts/build-line-jsons.php)
scripts/cache-gtfs/

# Images stations (regenerees par scripts/build-station-hero.php depuis Wikimedia)
# A uploader manuellement via FTP en prod ou via un workflow GitHub dedie.
# IMPORTANT : ces fichiers ne sont PAS deployes par le workflow deploy.yml
# (qui checkout le repo). Sur o2switch, faire FTP manuel apres chaque run.
public_html/assets/img/stations/*/*.avif
public_html/assets/img/stations/*/*.webp
public_html/assets/img/stations/*/*.jpg

# Images lignes (regenerees par scripts/build-line-hero.php depuis Wikimedia)
# Meme regle que stations : FTP manuel apres chaque run.
public_html/assets/img/lines/*/*.avif
public_html/assets/img/lines/*/*.webp
public_html/assets/img/lines/*/*.jpg

# CSS minifies : artefacts de build generes en CI (deploy.yml etape "Minify CSS")
# avant l'upload FTP. Source unique de verite au repo = .css source lisible (RGPD).
# Le helper asset() (core/bootstrap.php) bascule automatiquement .css -> .min.css
# si le minifie est present. Local Mac = sert .css source, prod = sert .min.css.
public_html/assets/css/*.min.css

# Critical CSS above-the-fold : artefacts de build (deploy.yml etape "Extract
# critical CSS"). Inlines dans <style> par Template::getCriticalCss(). Si absent
# en local, fallback synchrone classique (cf. base.php). Jamais commites.
public_html/assets/css/critical-*.css
