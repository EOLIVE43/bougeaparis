    "trivia": [
        {
            "icon": "🎪",
            "title": "Cirque d'Hiver Bouglione (1852)",
            "content": "Le <strong>Cirque d'Hiver Bouglione</strong>, à 5 min à pied, est le <strong>plus ancien cirque permanent du monde</strong> encore en activité. <strong>Construit en 1852</strong> par l'architecte <strong>Jacques-Ignace Hittorff</strong>. <strong>Inauguré par Napoléon III</strong> sous le nom <strong>« Cirque Napoléon »</strong>. <strong>Bâtiment en forme de polygone à 20 côtés</strong>. <strong>Famille Bouglione</strong> propriétaire depuis <strong>1934</strong>. <strong>Classé monument historique en 1975</strong>. <strong>~30 spectacles/an</strong>."
        },
        {
            "icon": "🏘️",
            "title": "11e, du faubourg ouvrier au quartier tendance",
            "content": "Le <strong>11e arrondissement</strong> (~150 000 habitants) est historiquement un <strong>quartier populaire et ouvrier</strong>. <strong>Faubourg Saint-Antoine</strong>, ancien quartier des <strong>artisans du meuble</strong>. À partir des années 1990, <strong>gentrification</strong> avec installation de <strong>bars, restaurants tendance</strong> autour des rues <strong>Oberkampf, Jean-Pierre Timbaud, Saint-Maur</strong>."
        }
