    "trivia": [
        {
            "icon": "📜",
            "title": "Le Peletier, député aux États généraux",
            "content": "<strong>Louis-Michel le Peletier de Saint-Fargeau</strong> (1760-1793), <strong>magistrat et homme politique français</strong>. <strong>Premier président du Parlement de Paris</strong>. <strong>Député de la noblesse aux États généraux de 1789</strong>, il <strong>se rallie au tiers état</strong>. <strong>Député de l'Yonne</strong> à la Convention. <strong>Vote la mort du roi</strong> Louis XVI (21 janvier 1793)."
        },
        {
            "icon": "🏛️",
