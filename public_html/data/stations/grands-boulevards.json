    "trivia": [
        {
            "icon": "🕯️",
            "title": "Musée Grévin (1882), musée de cire",
            "content": "Le <strong>Musée Grévin</strong>, à 2 min à pied (10 boulevard Montmartre), est <strong>fondé en 1882</strong> par <strong>Arthur Meyer</strong> (journaliste) et <strong>Alfred Grévin</strong> (caricaturiste). <strong>Musée de cire</strong> à l'image du Madame Tussauds londonien. <strong>~250 personnages</strong> historiques et contemporains : <strong>Napoléon, Louis XIV, Picasso, De Gaulle, Brigitte Bardot, Elvis Presley</strong>. <strong>Décors historiques</strong> (Versailles, Hollywood). <strong>~700 000 visiteurs/an</strong>."
        },
        {
            "icon": "🎭",
            "title": "Passages Jouffroy et Verdeau",
            "content": "Les <strong>passages Jouffroy</strong> (1846) et <strong>Verdeau</strong> (1847), à proximité immédiate, sont parmi les <strong>plus beaux passages couverts</strong> de Paris. <strong>Verrières</strong>, <strong>mosaïques au sol</strong>, <strong>devantures boutiques XIXe</strong>. <strong>Premier passage chauffé</strong> à Paris (Jouffroy). <strong>Librairies anciennes, antiquaires, salons de thé, boutiques curieuses</strong>. <strong>Patrimoine emblématique</strong> du <strong>Paris du XIXe siècle</strong>."
        }
    ],
