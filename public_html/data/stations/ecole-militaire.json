    "trivia": [
        {
            "icon": "🎖️",
            "title": "École Militaire (1751-1772), Gabriel et Louis XV",
            "content": "L'<strong>École Militaire</strong>, à la sortie, est un <strong>édifice du XVIIIe siècle</strong> construit de <strong>1751 à 1772</strong> sous <strong>Louis XV</strong>. Conçue par l'<strong>architecte Ange-Jacques Gabriel</strong> (1698-1782), <strong>premier architecte du roi</strong>, également auteur du <strong>Petit Trianon</strong> et de la <strong>place de la Concorde</strong>. <strong>Façade néo-classique</strong> avec <strong>colonnade corinthienne</strong>. Initialement <strong>établissement militaire d'élite</strong>. <strong>Napoléon Bonaparte</strong> y étudia comme <strong>cadet</strong> en <strong>1784</strong>."
        },
        {
            "icon": "🗼",
            "title": "Champ-de-Mars, du terrain militaire au parc",
            "content": "Le <strong>Champ-de-Mars</strong>, à proximité, est à l'origine un <strong>terrain d'exercices militaires</strong> de l'École Militaire. Au cours du XIXe siècle, transformé en <strong>parc public</strong> de <strong>24 hectares</strong>. Lieu emblématique des <strong>Expositions universelles</strong> de <strong>1855, 1867, 1878, 1889</strong> (Tour Eiffel construite à cette occasion), <strong>1900</strong>. Aujourd'hui, <strong>l'un des parcs les plus visités de Paris</strong>, au pied de la <strong>Tour Eiffel</strong>."
        }
    ],
