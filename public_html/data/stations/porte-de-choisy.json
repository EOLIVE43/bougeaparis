        },
        {
            "question": "Pour Tang Frères ?",
            "answer": "<strong>~3 min à pied</strong> avenue d'Ivry."
        },
        {
            "question": "Pour le Nouvel An chinois ?",
            "answer": "<strong>Défilé annuel</strong> dans le 13e (fin janvier / février selon les années)."
        },
        {
            "question": "La station est-elle accessible PMR ?",
            "answer": "<strong>Partiellement</strong>."
        }
    ],
