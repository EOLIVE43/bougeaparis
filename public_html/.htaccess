# =============================================================
# BougeaParis.fr — .htaccess o2switch
# =============================================================
# Sections :
#   1. Sécurité : protection fichiers sensibles
#   2. Compression : Brotli (déjà actif côté o2switch) + gzip
#   3. Cache HTTP : Cache-Control + Expires sur assets statiques
#   4. Front controller : tout vers index.php (sauf assets réels)
#
# IMPORTANT : le bloc 4 (mod_rewrite) est NÉCESSAIRE — sans lui,
# o2switch retourne 404 Apache sur toutes les URLs propres comme
# /metro/, /metro/station/chatelet/, /mentions-legales/.
# Régression constatée et corrigée le 2026-05-09.
# =============================================================


# -------------------------------------------------------------
# 1. Sécurité — fichiers sensibles
# -------------------------------------------------------------
<FilesMatch "^(secrets\.php|composer\.(json|lock)|\.env|\.git.*)$">
    Require all denied
</FilesMatch>

<FilesMatch "^config/secrets\.php$">
    Require all denied
</FilesMatch>

# Désactive la liste de répertoires
Options -Indexes


# -------------------------------------------------------------
# 2. Compression — Brotli prioritaire, gzip en fallback
# -------------------------------------------------------------
# o2switch a déjà Brotli actif côté serveur (vérifié 2026-05-09 :
# `Content-Encoding: br` confirmé sur bundle.css et HTML page).
# On déclare quand même les filtres au cas où une migration future
# nécessiterait une activation explicite.
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json text/plain text/xml application/xml image/svg+xml application/rss+xml application/atom+xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/plain text/xml application/xml image/svg+xml application/rss+xml application/atom+xml
</IfModule>


# -------------------------------------------------------------
# 3. Cache HTTP — assets statiques longue durée
# -------------------------------------------------------------
# Stratégie :
# - Assets versionnés via ?v=<mtime> par le helper asset() PHP →
#   on peut sans risque cacher 1 an avec immutable. Quand le
#   fichier change, l'URL change.
# - Images : noms uniques par station/ligne, jamais réécrites en
#   place → 1 an immutable safe.
# - HTML : cache court (5 min) car contenu peut changer.
<IfModule mod_expires.c>
    ExpiresActive On

    # Assets statiques longue durée
    ExpiresByType text/css                    "access plus 1 year"
    ExpiresByType application/javascript      "access plus 1 year"
    ExpiresByType text/javascript             "access plus 1 year"
    ExpiresByType image/avif                  "access plus 1 year"
    ExpiresByType image/webp                  "access plus 1 year"
    ExpiresByType image/jpeg                  "access plus 1 year"
    ExpiresByType image/png                   "access plus 1 year"
    ExpiresByType image/svg+xml               "access plus 1 year"
    ExpiresByType image/x-icon                "access plus 1 year"
    ExpiresByType font/woff                   "access plus 1 year"
    ExpiresByType font/woff2                  "access plus 1 year"
    ExpiresByType application/font-woff       "access plus 1 year"
    ExpiresByType application/font-woff2      "access plus 1 year"

    # HTML — court (contenu dynamique : trafic, articles, état audit)
    ExpiresByType text/html                   "access plus 5 minutes"

    # JSON public (peu probable, mais au cas où)
    ExpiresByType application/json            "access plus 5 minutes"

    # Flux RSS — 1 heure
    ExpiresByType application/rss+xml         "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control fort + immutable sur les assets versionnés
    <FilesMatch "\.(css|js|avif|webp|jpe?g|png|gif|svg|ico|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML : pas d'immutable, must-revalidate court
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>

    # Sécurité : entêtes utiles
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>


# -------------------------------------------------------------
# 4. Front controller — tout vers index.php sauf fichiers réels
# -------------------------------------------------------------
# Sans ces règles, o2switch retourne 404 sur les URLs propres
# (/metro/, /mentions-legales/, etc.). Nécessaire pour le
# routing PHP custom de BougeaParis.fr.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si une requête matche un fichier ou un dossier réel → on sert
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Sinon → index.php (front controller PHP)
    RewriteRule ^ index.php [L]
</IfModule>
